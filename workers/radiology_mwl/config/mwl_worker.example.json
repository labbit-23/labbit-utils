{
  "source": {
    "poll_url": "https://api.sdrc.in/py/delivery/department-worklist?department_name=radiology",
    "poll_method": "GET",
    "poll_headers": {},
    "poll_timeout_seconds": 20,
    "items_path": "items",
    "performed_field": "performed",
    "pending_value": "0",
    "id_field": "id",
    "scheduled_date_field": "reqdt",
    "scheduled_time_field": "reqtm"
  },
  "destination": {
    "aet": "SDRC_RAD_AE",
    "host": "127.0.0.1",
    "port": 4242
  },
  "mwl": {
    "create_url": "http://127.0.0.1:8042/wl-ingest",
    "create_method": "POST",
    "create_headers": {},
    "timeout_seconds": 20,
    "transport": "multipart_file",
    "outbox_dir": "./outbox",
    "payload_fields": {
      "accession_number": "reqno",
      "patient_id": "patient_id",
      "patient_name": "patient_name",
      "patient_sex": "patient_sex",
      "patient_dob": "patient_dob",
      "modality": "modality",
      "scheduled_datetime": "scheduled_datetime",
      "requested_procedure_description": "procedure_name"
    },
    "defaults": {
      "modality": "CR",
      "institution_name": "SDRC",
      "requested_procedure_description": "RADIOLOGY",
      "scheduled_step_description": "RADIOLOGY"
    }
  },
  "worker": {
    "poll_seconds": 15,
    "batch_size": 50,
    "log_level": "INFO",
    "state_db_path": "./state/radiology_mwl_state.sqlite3"
  }
}
